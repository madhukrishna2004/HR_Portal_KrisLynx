# ─────────────────────────────────────────────────────────────────
# KrisLynx LLP HR Portal  –  Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env for local development.
# On Render, set these in the Dashboard → Environment tab.
# NEVER commit .env or serviceAccountKey.json to git.
# ─────────────────────────────────────────────────────────────────

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Firebase Project
FIREBASE_PROJECT_ID=miyraa-59c25
FIREBASE_STORAGE_BUCKET=miyraa-59c25.appspot.com

# Firebase Client SDK (used in browser)
FIREBASE_API_KEY=AIzaSyC_REPLACE_WITH_YOUR_KEY
FIREBASE_AUTH_DOMAIN=miyraa-59c25.firebaseapp.com
FIREBASE_MESSAGING_SENDER_ID=REPLACE_SENDER_ID
FIREBASE_APP_ID=REPLACE_APP_ID

# Firebase Admin SDK – paste entire JSON content of serviceAccountKey.json
# as a single-line string (minified JSON)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
