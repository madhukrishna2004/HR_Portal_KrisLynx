# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
PORT=5000

# Firebase Client Config (used in frontend)
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Firebase Admin (for Render / production)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Zoho Mail SMTP (for sending emails)
ZOHO_EMAIL=hr@krislynx.com
ZOHO_PASSWORD=your-zoho-app-password
ZOHO_SMTP_HOST=smtp.zoho.in
ZOHO_SMTP_PORT=587
ZOHO_FROM_NAME=LynxPort - KrisLynx LLP
